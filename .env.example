# Скопіюй цей файл у ".env" і встав свої значення.

# Токен, який дасть @BotFather після створення бота
BOT_TOKEN=123456:ABC-DEF...

# Твій особистий chat_id — куди бот надсилатиме заявки.
# Дізнатись: запусти бота, напиши йому /whoami — він покаже число.
OWNER_CHAT_ID=

# HTTPS-адреса сторінки з 3D-моделлю (webapp/index.html).
# Захости папку webapp/ на GitHub Pages / Netlify / Vercel і встав сюди лінк.
# Обов'язково HTTPS — Telegram Web App не відкриває http:// чи localhost.
# Приклад: https://username.github.io/TelegramChatBot/
WEBAPP_URL=
